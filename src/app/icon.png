<svg width="512" height="512" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="marbleBg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#ecedf6"/>
      <stop offset="35%" stop-color="#e0e2f0"/>
      <stop offset="70%" stop-color="#d4d6ea"/>
      <stop offset="100%" stop-color="#c8cae2"/>
    </linearGradient>
    <linearGradient id="blueGrad" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#3b82f6"/>
      <stop offset="100%" stop-color="#1d4ed8"/>
    </linearGradient>
    <filter id="tglow" x="-40%" y="-40%" width="180%" height="180%">
      <feGaussianBlur in="SourceGraphic" stdDeviation="18" result="blur"/>
      <feFlood flood-color="#3b82f6" flood-opacity="0.5" result="color"/>
      <feComposite in="color" in2="blur" operator="in" result="coloredBlur"/>
      <feMerge>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
    <radialGradient id="cornerLight" cx="20%" cy="15%" r="50%">
      <stop offset="0%" stop-color="#ffffff" stop-opacity="0.18"/>
      <stop offset="100%" stop-color="#ffffff" stop-opacity="0"/>
    </radialGradient>
  </defs>

  <!-- fond marbre -->
  <rect x="0" y="0" width="512" height="512" rx="116" fill="url(#marbleBg)"/>

  <!-- veinures marbre -->
  <path d="M 30 66 Q 128 30 200 128 Q 256 200 348 146 Q 420 102 494 138" fill="none" stroke="#b8bad8" stroke-width="3" opacity="0.55"/>
  <path d="M 0 200 Q 92 154 165 248 Q 228 322 330 274 Q 420 226 512 262" fill="none" stroke="#bbbdd8" stroke-width="2.5" opacity="0.4"/>
  <path d="M 18 348 Q 110 300 190 384 Q 264 454 366 410 Q 446 374 504 402" fill="none" stroke="#b0b2d2" stroke-width="2" opacity="0.35"/>
  <path d="M 55 468 Q 164 432 248 490 Q 330 540 432 504" fill="none" stroke="#b8bad4" stroke-width="1.8" opacity="0.3"/>
  <path d="M 80 30 Q 110 110 66 200 Q 30 278 73 366 Q 116 446 80 504" fill="none" stroke="#c0c2da" stroke-width="2" opacity="0.3"/>
  <path d="M 432 18 Q 468 102 432 190 Q 396 270 446 358 Q 490 430 446 504" fill="none" stroke="#b8bad6" stroke-width="1.8" opacity="0.25"/>

  <!-- lumière coin -->
  <ellipse cx="102" cy="80" rx="138" ry="88" fill="url(#cornerLight)"/>

  <!-- bordure -->
  <rect x="3" y="3" width="506" height="506" rx="113" fill="none" stroke="#b4b6d8" stroke-width="3"/>

  <!-- T avec halo -->
  <text x="256" y="382"
    font-family="Georgia, serif"
    font-size="365"
    font-style="normal"
    font-weight="400"
    fill="url(#blueGrad)"
    text-anchor="middle"
    filter="url(#tglow)">T</text>
</svg>
